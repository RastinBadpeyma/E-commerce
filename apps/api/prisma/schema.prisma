generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}
datasource db {
  provider = "postgresql"
  schemas  = ["identity"] 

}


enum UserRole {
  ADMIN
  CUSTOMER
  @@schema("identity")
}
model User {
  id        String   @id @default(uuid())
  phoneNumber String   @unique
  role        UserRole @default(CUSTOMER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  refreshTokens RefreshToken[]
  @@schema("identity")
}
model OtpCode {
  id          String   @id @default(uuid())

  phoneNumber String

  code        String

  expiresAt   DateTime

  usedAt      DateTime?

  createdAt   DateTime @default(now())

  @@index([phoneNumber])
  @@schema("identity")
}

model RefreshToken {
  id        String   @id @default(uuid())

  tokenHash String   @unique

  userId    String

  user      User @relation(fields: [userId], references: [id])

  expiresAt DateTime

  revokedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@schema("identity")
}




